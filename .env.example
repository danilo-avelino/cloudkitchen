# Configuração StockKitchen — copie para .env.local (gitignored) e preencha
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Opcional · build version mostrada no StatusBar
VITE_APP_VERSION=2.5.0

# Opcional - Analise de mercado
# Estes endpoints ficam no seu backend/Edge Function. A chave OpenAI nao deve
# ser exposta no frontend; use VITE_MARKET_OPENAI_KEY_ENDPOINT apenas para enviar
# a chave ao backend por HTTPS e salva-la de forma segura no servidor.
VITE_MARKET_ANALYSIS_ENDPOINT=
VITE_MARKET_OPENAI_KEY_ENDPOINT=

# Supabase Edge Function secrets (configure no Supabase, nao no frontend)
MARKET_KEY_ENCRYPTION_SECRET=
OPENAI_MODEL=gpt-4.1-mini
